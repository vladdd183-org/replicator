@click.option("--limit", "-l", default=20, help="Maximum items to show")
@click.option("--offset", "-o", default=0, help="Offset for pagination")
@with_container
async def list_{{ name_plural }}(container, limit: int, offset: int) -> None:
    """List all {{ name_plural }}.
    
    Examples:
        litestar {{ name_plural }} list
        litestar {{ name_plural }} list --limit 50
    """
    query = await container.get(List{{ name_plural_pascal }}Query)
    result = await query.execute(List{{ name_plural_pascal }}QueryInput(limit=limit, offset=offset))
    
    if not result.{{ name_plural }}:
        console.print("[yellow]No {{ name_plural }} found.[/yellow]")
        return
    
    table = Table(title="{{ name_plural_pascal }}")
    table.add_column("ID", style="cyan")
    table.add_column("Created At", style="green")
    # TODO: Add more columns based on your model
    # table.add_column("Name", style="white")
    
    for item in result.{{ name_plural }}:
        table.add_row(
            str(item.id),
            str(item.created_at),
            # item.name,
        )
    
    console.print(table)
    console.print(f"\n[dim]Total: {result.total} | Showing: {len(result.{{ name_plural }})}[/dim]")


