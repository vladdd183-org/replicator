# Application
APP_NAME=porto-litestar
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Logfire
LOGFIRE_TOKEN=your-logfire-token
LOGFIRE_PROJECT_NAME=porto-litestar

# Security
SECRET_KEY=your-secret-key-here

# CORS
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
