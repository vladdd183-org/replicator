# =============================================================================
# TASK WITH DISHKA DI
# =============================================================================

@broker.task
async def send_${entity_lower}_notification_task(
    ${entity_lower}_id: str,
    notification_type: str,
    container: AsyncContainer = TaskiqDepends(),
) -> dict:
    """Send notification for ${entity_lower}.
    
    Uses Dishka container for dependency injection.
    
    Args:
        ${entity_lower}_id: UUID as string
        notification_type: Type of notification
        container: Dishka container (injected by TaskIQ)
    """
    logfire.info(
        "Sending notification",
        ${entity_lower}_id=${entity_lower}_id,
        notification_type=notification_type,
    )
    
    async with container() as request_container:
        # Get dependencies from container
        query = await request_container.get(Get${Entity}Query)
        ${entity_lower} = await query.execute(Get${Entity}QueryInput(${entity_lower}_id=UUID(${entity_lower}_id)))
        
        if not ${entity_lower}:
            logfire.warning("${Entity} not found", ${entity_lower}_id=${entity_lower}_id)
            return {"status": "error", "error": "${entity_lower}_not_found"}
        
        # Send notification logic here
        # email_service = await request_container.get(EmailService)
        # await email_service.send(${entity_lower}.email, notification_type)
        
        logfire.info("Notification sent", ${entity_lower}_id=${entity_lower}_id)
        return {"status": "success"}


