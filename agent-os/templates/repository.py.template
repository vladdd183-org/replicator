"""${Entity}Repository - Data access layer for ${Entity}."""

from uuid import UUID
from datetime import datetime

from src.Ship.Parents.Repository import Repository
from src.Containers.${Section}.${Module}.Models.${Entity} import ${Entity}


class ${Entity}Repository(Repository[${Entity}]):
    """Repository for ${Entity} data access.
    
    Provides CRUD operations and domain-specific queries.
    Inherits from base Repository[T].
    
    Inherited methods:
    - add(entity) - Create new entity
    - update(entity) - Update existing entity
    - delete(entity) - Delete entity
    - get(id) - Get by UUID
    
    Example:
        repo = ${Entity}Repository()
        ${entity_lower} = await repo.find_by_email("test@example.com")
    """
    
    model = ${Entity}
    
    # =========================================================================
    # DOMAIN-SPECIFIC QUERIES
    # =========================================================================
    
    async def find_by_email(self, email: str) -> ${Entity} | None:
        """Find ${entity_lower} by email.
        
        Args:
            email: Email address to search
            
        Returns:
            ${Entity} or None if not found
        """
        return await ${Entity}.objects().where(
            ${Entity}.email == email
        ).first()
    
    async def find_active(self, limit: int = 100) -> list[${Entity}]:
        """Find all active ${entities_lower}.
        
        Args:
            limit: Max number of results
            
        Returns:
            List of active ${entities_lower}
        """
        return await (
            ${Entity}.objects()
            .where(${Entity}.is_active == True)
            .limit(limit)
            .order_by(${Entity}.created_at, ascending=False)
        )
    
    async def exists_by_email(self, email: str) -> bool:
        """Check if ${entity_lower} with email exists.
        
        Args:
            email: Email to check
            
        Returns:
            True if exists
        """
        return await ${Entity}.exists().where(${Entity}.email == email)
    
    # =========================================================================
    # HOOKS (optional - called by base Repository)
    # =========================================================================
    
    async def _on_add(self, entity: ${Entity}) -> None:
        """Hook called before adding entity.
        
        Use for setting defaults, timestamps, etc.
        """
        if not entity.created_at:
            entity.created_at = datetime.utcnow()
    
    async def _on_update(self, entity: ${Entity}) -> None:
        """Hook called before updating entity.
        
        Use for updating timestamps, audit fields, etc.
        """
        entity.updated_at = datetime.utcnow()


