"""${Module}UnitOfWork - Transaction management for ${Module}."""

from collections.abc import Callable, Coroutine
from typing import Any

from litestar import Litestar

from src.Ship.Parents.UnitOfWork import BaseUnitOfWork
from src.Containers.${Section}.${Module}.Data.Repositories.${Entity}Repository import ${Entity}Repository


class ${Module}UnitOfWork(BaseUnitOfWork):
    """Unit of Work for ${Module} module.
    
    Manages transactions and domain events for ${Module}.
    
    Features:
    - Transaction management (commit/rollback)
    - Domain event collection and publishing
    - Repository access through properties
    
    Example:
        async with uow:
            ${entity_lower} = ${Entity}(...)
            await uow.${entities_lower}.add(${entity_lower})
            uow.add_event(${Entity}Created(${entity_lower}_id=${entity_lower}.id))
            await uow.commit()
        # Transaction committed, events published
    """
    
    def __init__(
        self,
        _emit: Callable[..., Coroutine[Any, Any, None]] | None = None,
        _app: Litestar | None = None,
    ) -> None:
        """Initialize UnitOfWork.
        
        Args:
            _emit: Event emitter function (app.emit from Litestar)
            _app: Litestar app instance (for accessing plugins like Channels)
        """
        super().__init__(_emit=_emit, _app=_app)
        
        # Initialize repositories
        self._${entities_lower}: ${Entity}Repository | None = None
    
    # =========================================================================
    # REPOSITORY PROPERTIES (lazy initialization)
    # =========================================================================
    
    @property
    def ${entities_lower}(self) -> ${Entity}Repository:
        """Get ${Entity}Repository.
        
        Lazily initialized on first access.
        """
        if self._${entities_lower} is None:
            self._${entities_lower} = ${Entity}Repository()
        return self._${entities_lower}
    
    # Add more repositories as needed:
    # @property
    # def other_entities(self) -> OtherRepository:
