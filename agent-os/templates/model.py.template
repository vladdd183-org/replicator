"""${Entity} - Piccolo ORM model.

Domain model representing ${entity_lower} entity in the database.
"""

from uuid import uuid4
from datetime import datetime

from piccolo.table import Table
from piccolo.columns import UUID, Varchar, Boolean, Timestamptz, Text


class ${Entity}(Table, tablename="${entities_lower}"):
    """${Entity} domain model.
    
    Represents ${entity_lower} entity in the database.
    Uses Piccolo ORM for async database operations.
    
    Attributes:
        id: Primary key (UUID)
        email: Unique email address
        name: Display name
        is_active: Whether ${entity_lower} is active
        created_at: Creation timestamp
        updated_at: Last update timestamp
    """
    
    # Primary key
    id = UUID(
        primary_key=True,
        default=uuid4,
        help_text="Unique identifier",
    )
    
    # Core fields
    email = Varchar(
        length=255,
        unique=True,
        index=True,
        help_text="Email address",
    )
    
    name = Varchar(
        length=100,
        help_text="Display name",
    )
    
    # Optional fields
    # password_hash = Varchar(length=255, null=True)
    # description = Text(null=True, default=None)
    
    # Status
    is_active = Boolean(
        default=True,
        help_text="Whether ${entity_lower} is active",
    )
    
    # Timestamps
    created_at = Timestamptz(
        default=datetime.utcnow,
        help_text="Creation timestamp",
    )
    
    updated_at = Timestamptz(
        null=True,
        default=None,
        help_text="Last update timestamp",
    )
    
    # Add more columns as needed:
    # role = Varchar(length=50, default="user")
    # last_login = Timestamptz(null=True)
    # metadata = JSONB(null=True)  # For flexible data


